# CONTAR
conteo_clase_sitios <- homicidios %>% count(Clase.de.sitio, sort = TRUE)
homicidios <- read.csv("Homicidios.csv",
sep = ";",
fileEncoding = "Latin1",
check.names = TRUE)
# Corregir nombres de algunas columnas
library(dplyr)
homicidios <- homicidios %>%
rename(Dia = D.a,
Pais_Nacimiento = Pa.s.de.nacimiento,
Profesion = Profesi.n)
head(homicidios)
str(homicidios)
summary(homicidios)
library(dplyr)
homicidios |> count(Departamento,sort=TRUE)
install.packages("ggplot2")
# CONTAR
conteo_clase_sitios <- homicidios %>% count(Clase.de.sitio, sort = TRUE)
ggplot(aes(x=n,y=reorder(conteo_clase_sitios,n))) + geom_col(fill = "blue") +
labs(title = " lugares de los hechos",x="cantidad",y="sitio") +
theme_minimal()
